# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# For Docker Compose: use service name "postgres" as host
DATABASE_URL=postgresql://postgres:password@localhost:5432/habitflow

# ─── Redis ────────────────────────────────────────────────────────────────────
# For Docker Compose: use service name "redis" as host
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use long random strings (min 32 chars) — never share or commit real values
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to the URL where your frontend is hosted
CORS_ORIGIN=http://localhost
